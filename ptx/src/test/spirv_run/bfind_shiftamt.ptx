.version 6.5
.target sm_30
.address_size 64

.visible .entry bfind_shiftamt(
	.param .u64 input,
	.param .u64 output
)
{
	.reg .u64 	    in_addr;
    .reg .u64 	    out_addr;
    .reg .b32       temp<3>;

	ld.param.u64 	in_addr, [input];
    ld.param.u64 	out_addr, [output];

    ld.b32          temp0, [in_addr];
	ld.b32          temp1, [in_addr+4];
	ld.b32          temp2, [in_addr+8];
	bfind.shiftamt.u32         temp0, temp0;
	bfind.shiftamt.u32         temp1, temp1;
	bfind.shiftamt.u32         temp2, temp2;
    st.b32          [out_addr], temp0;
	st.b32          [out_addr+4], temp1;
	st.b32          [out_addr+8], temp2;
	ret;
}
