.version 6.5
.target sm_30
.address_size 64

.visible .entry exit_(
    .param .u64 input,
    .param .u64 output
)
{
    .reg .u64   in_addr;
    .reg .u64   out_addr;
    .reg .u32   temp;
    .reg .u32   temp2;
    .reg .pred  p;

    ld.param.u64    in_addr, [input];
    ld.param.u64    out_addr, [output];

    ld.u32          temp, [in_addr];
    st.u32          [out_addr], temp;
    setp.eq.u32     p, temp, temp;      // always true
    @p exit;                            // terminate the thread here...
    mov.u32         temp2, 999;
    st.u32          [out_addr], temp2;  // ...so this overwrite must NOT happen
    ret;
}
