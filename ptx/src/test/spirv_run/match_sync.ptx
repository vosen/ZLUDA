.version 7.0
.target sm_70
.address_size 64

.visible .entry match_sync(
    .param .u64 output
)
{
    .reg .u64         out_addr;
    .reg .u64         out_index;
    .reg .u32         thread_id;
    .reg .u32         source;
    .reg .u32         result;

    ld.param.u64      out_addr, [output];
    mov.u32           thread_id, %tid.x;

    // source = thread_id & 1 (0 for even lanes, 1 for odd lanes)
    and.b32           source, thread_id, 1;

    // result = bitmask of all lanes in the warp with the same source value
    // even lanes: result = 0x55555555, odd lanes: result = 0xAAAAAAAA
    match.any.sync.b32 result, source, 0xFFFFFFFF;

    // Store u32 result at output[thread_id * 4]
    cvt.u64.u32       out_index, thread_id;
    mul.lo.u64        out_index, out_index, 4;
    add.u64           out_addr, out_addr, out_index;
    st.u32            [out_addr], result;

    ret;
}
