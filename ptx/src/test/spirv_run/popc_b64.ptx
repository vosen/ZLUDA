.version 6.5
.target sm_30
.address_size 64

.visible .entry popc_b64(
	.param .u64 input,
	.param .u64 output
)
{
	.reg .u64 	    in_addr;
    .reg .u64 	    out_addr;
	.reg .b32       temp32;
    .reg .b64       temp64;

	ld.param.u64 	in_addr, [input];
    ld.param.u64 	out_addr, [output];

    ld.b64          temp64, [in_addr];
	popc.b64        temp32, temp64;
    st.b32          [out_addr], temp32;
	ret;
}
