.version 6.5
.target sm_30
.address_size 64

.visible .entry setp_bool_and(
    .param .u64 input,
    .param .u64 output
)
{
    .reg .u64       in_addr;
    .reg .u64       out_addr;
    .reg .u32       a, b, c_val, result;
    .reg .pred      p, c_pred;

    ld.param.u64    in_addr, [input];
    ld.param.u64    out_addr, [output];

    ld.u32          a, [in_addr];
    ld.u32          b, [in_addr + 4];
    ld.u32          c_val, [in_addr + 8];
    setp.ne.u32     c_pred, c_val, 0;
    setp.lt.and.u32 p, a, b, !c_pred;
    selp.u32        result, 1, 0, p;
    st.u32          [out_addr], result;

    ret;
}
