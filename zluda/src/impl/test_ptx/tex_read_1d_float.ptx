.version 6.5
.target sm_30
.address_size 64
.global .texref tex;
.visible .entry tex_read_1d_float(
    .param .u64 out_ptr,
    .param .f32 coord_x
) {
    .reg .u64 %rd1;
    .reg .f32 %fx;
    .reg .f32 %f0, %f1, %f2, %f3;
    ld.param.u64 %rd1, [out_ptr];
    ld.param.f32 %fx, [coord_x];
    tex.1d.v4.f32.f32 {%f0, %f1, %f2, %f3}, [tex, {%fx}];
    st.global.v4.f32 [%rd1], {%f0, %f1, %f2, %f3};
    ret;
}
