.version 6.5
.target sm_30
.address_size 64
.global .texref tex;
.visible .entry tex_read_1d_int(
    .param .u64 out_ptr,
    .param .f32 coord_x
) {
    .reg .u64 %rd1;
    .reg .f32 %fx;
    .reg .s32 %r0, %r1, %r2, %r3;
    ld.param.u64 %rd1, [out_ptr];
    ld.param.f32 %fx, [coord_x];
    tex.1d.v4.s32.f32 {%r0, %r1, %r2, %r3}, [tex, {%fx}];
    st.global.v4.s32 [%rd1], {%r0, %r1, %r2, %r3};
    ret;
}
