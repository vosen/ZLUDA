.version 6.5
.target sm_30
.address_size 64
.global .texref tex;
.visible .entry tex_read_3d_float(
    .param .u64 out_ptr,
    .param .f32 coord_x,
    .param .f32 coord_y,
    .param .f32 coord_z
) {
    .reg .u64 %rd1;
    .reg .f32 %fx, %fy, %fz;
    .reg .f32 %f0, %f1, %f2, %f3;
    ld.param.u64 %rd1, [out_ptr];
    ld.param.f32 %fx, [coord_x];
    ld.param.f32 %fy, [coord_y];
    ld.param.f32 %fz, [coord_z];
    tex.3d.v4.f32.f32 {%f0, %f1, %f2, %f3}, [tex, {%fx, %fy, %fz, %fz}];
    st.global.v4.f32 [%rd1], {%f0, %f1, %f2, %f3};
    ret;
}
