.version 6.5
.target sm_30
.address_size 64
.global .texref tex;
.visible .entry tex_read_3d_float_s32coord(
    .param .u64 out_ptr,
    .param .s32 coord_x,
    .param .s32 coord_y,
    .param .s32 coord_z
) {
    .reg .u64 %rd1;
    .reg .s32 %ix, %iy, %iz;
    .reg .f32 %f0, %f1, %f2, %f3;
    ld.param.u64 %rd1, [out_ptr];
    ld.param.s32 %ix, [coord_x];
    ld.param.s32 %iy, [coord_y];
    ld.param.s32 %iz, [coord_z];
    tex.3d.v4.f32.s32 {%f0, %f1, %f2, %f3}, [tex, {%ix, %iy, %iz, %iz}];
    st.global.v4.f32 [%rd1], {%f0, %f1, %f2, %f3};
    ret;
}
