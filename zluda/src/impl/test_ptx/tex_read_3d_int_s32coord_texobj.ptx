.version 6.5
.target sm_30
.address_size 64
.visible .entry tex_read_3d_int_s32coord_texobj(
    .param .u64 out_ptr,
    .param .u64 texobj,
    .param .s32 coord_x,
    .param .s32 coord_y,
    .param .s32 coord_z
) {
    .reg .u64 %rd1, %rd2;
    .reg .s32 %ix, %iy, %iz;
    .reg .s32 %r0, %r1, %r2, %r3;
    ld.param.u64 %rd1, [out_ptr];
    ld.param.u64 %rd2, [texobj];
    ld.param.s32 %ix, [coord_x];
    ld.param.s32 %iy, [coord_y];
    ld.param.s32 %iz, [coord_z];
    tex.3d.v4.s32.s32 {%r0, %r1, %r2, %r3}, [%rd2, {%ix, %iy, %iz, %iz}];
    st.global.v4.s32 [%rd1], {%r0, %r1, %r2, %r3};
    ret;
}
